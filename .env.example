VITE_API_URL="http://localhost:8080/api"
VITE_SESSION_SECRET_KEY="your-secret-key"
# Prefer SESSION_SECRET_KEY in production (server-only, no VITE_ prefix)
# SESSION_SECRET_KEY="your-secret-key"
VITE_GOOGLE_CLIENT_ID=""

# Server-only Azure Monitor OpenTelemetry (never use VITE_ prefix)
# Parsed at module load by src/server/telemetry/config.ts
TELEMETRY_ENABLED=false
TELEMETRY_DEBUG=false
TELEMETRY_PROVIDER=azure
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
OTEL_SERVICE_NAME=loops-app
TELEMETRY_SAMPLING_RATIO=1
# Optional: ENV overrides NODE_ENV for isProduction / sampling defaults
# ENV=production

# Browser RUM — Application Insights JavaScript SDK (public; visible in bundle)
# Do not send passwords, tokens, auth headers, form bodies, or PII.
VITE_TELEMETRY_ENABLED=false
VITE_APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...